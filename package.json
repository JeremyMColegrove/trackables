{
	"name": "trackable",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build --webpack",
		"start": "next start",
		"start:standalone": "node .next/standalone/server.js",
		"docker:build": "npm run docker:build:arm64",
		"docker:build:amd64": "docker buildx build --platform linux/amd64 -t jeremycolegrove/trackable:amd64 --load .",
		"docker:build:arm64": "docker buildx build --platform linux/arm64 -t jeremycolegrove/trackable:arm64 --load .",
		"docker:up": "docker compose up -d trackable",
		"lint": "eslint",
		"format": "prettier --write \"**/*.{ts,tsx}\"",
		"test": "tsx --test",
		"translate": "npx gt generate && npm run translate:update",
		"translate:update": "node scripts/update-gt-translations.js",
		"typecheck": "tsc --noEmit",
		"db:publish": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:sql": "npx drizzle-kit export > ./example/init.sql"
	},
	"dependencies": {
		"@clerk/elements": "^0.24.13",
		"@clerk/localizations": "^4.2.3",
		"@clerk/nextjs": "^7.0.5",
		"@hookform/resolvers": "^5.2.2",
		"@internationalized/date": "^3.12.0",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.23",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@trpc/client": "^11.13.4",
		"@trpc/server": "^11.13.4",
		"@trpc/tanstack-react-query": "^11.13.4",
		"@types/lodash": "^4.17.24",
		"chrono-node": "^2.9.0",
		"class-variance-authority": "^0.7.1",
		"client-only": "^0.0.1",
		"clsx": "^2.1.1",
		"cron": "^4.4.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"gt-next": "^6.14.3",
		"gt-node": "^0.4.3",
		"ioredis": "^5.10.1",
		"jsdom": "^29.0.1",
		"liqe": "^3.8.5",
		"lodash": "^4.17.23",
		"lucide-react": "^0.577.0",
		"next": "16.1.7",
		"next-themes": "^0.4.6",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-aria-components": "^1.16.0",
		"react-dom": "^19.2.4",
		"react-draggable": "^4.5.0",
		"react-hook-form": "^7.71.2",
		"react-use-wizard": "^2.3.0",
		"recharts": "^2.15.4",
		"server-only": "^0.0.1",
		"shadcn": "^4.0.8",
		"sonner": "^2.0.7",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/jsdom": "^28.0.1",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-config-next": "16.1.7",
		"google-translate-api-x": "^10.7.2",
		"gt": "^2.12.0",
		"postcss": "^8",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
